---
layout: base
title: Listening
permalink: /listening/
---

<section class="section-block">
  <h1 class="section-title">Listening</h1>

  {% if albumwhale and albumwhale.length %}
    <ul class="site-list-of-posts">
      {% for item in albumwhale %}
        <li class="site-list-of-posts-item">
          <div class="site-list-link">
            <a href="{{ item.link }}">{{ item.title }}</a>
          </div>
          {% if item.date %}
            <time class="site-list-date" datetime="{{ item.date | htmlDateString }}">
              {{ item.date | dateDisplay }}
            </time>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No Album Whale entries yet.</p>
  {% endif %}
</section>
